TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
TELEGRAM_CHAT_ID=<your-telegram-chat-id>
OPENROUTER_API_KEY=<your-openrouter-api-key>

# Optional settings
OPENROUTER_MODEL=openai/gpt-4o-mini
# Comma-separated list shown by the /model Telegram command.
# OPENROUTER_MODELS=openai/gpt-4o-mini,anthropic/claude-sonnet-4.5,google/gemini-2.5-flash
POLL_INTERVAL_SECONDS=1800
MIN_SCORE=6
BEARISH_THRESHOLD=3
DAILY_DIGEST_HOUR=8
FEED_LOOKBACK_HOURS=2
REQUEST_TIMEOUT_SECONDS=10
AGENT_DATA_DIR=data
AGENT_LOG_DIR=logs

# --- Consolidated brief ---
# Combined news brief (stocks, Fed/rates, politics, global) cadence in hours,
# plus a fuller morning edition at DAILY_DIGEST_HOUR.
BRIEF_INTERVAL_HOURS=4
# Keep the brief as the only delivery (default). Set true to ALSO get an
# individual Telegram alert the moment each item clears MIN_SCORE.
REALTIME_ALERTS=false

# --- Social / web sources (X, Reddit, Exa via Agent-Reach upstream CLIs) ---
# Master switch. The agent degrades gracefully: any source whose CLI is not
# installed/authenticated is silently skipped (run /sources to see status).
ENABLE_SOCIAL=true
SOCIAL_TIMEOUT_SECONDS=30
# Pipe-separated search queries fed to every available social source.
# SOCIAL_QUERIES=stock market today|Federal Reserve rate decision|Trump tariffs|$NVDA OR $MSFT
# Comma-separated subreddits the agent pulls hot posts from (Reddit only).
# REDDIT_SUBREDDITS=stocks,wallstreetbets,investing,StockMarket,economy
#
# Setup for each source (enable only what you want):
#   X/Twitter : pipx install twitter-cli
#               export TWITTER_AUTH_TOKEN="..."   (from x.com browser cookies)
#               export TWITTER_CT0="..."
#   Reddit    : pipx install 'git+https://github.com/public-clis/rdt-cli.git'
#               rdt login        (or install OpenCLI desktop to reuse Chrome login)
#   Exa search: npm install -g mcporter
#               mcporter config add exa https://mcp.exa.ai/mcp   (free, no API key)

# Optional custom agent prompt. Use one of these, not both.
# ANALYSIS_PROMPT=Prioritize earnings, guidance, and AI infrastructure news.
# ANALYSIS_PROMPT_FILE=prompts/analysis_prompt.txt
