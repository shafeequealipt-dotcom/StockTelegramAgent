TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
TELEGRAM_CHAT_ID=<your-telegram-chat-id>
OPENROUTER_API_KEY=<your-openrouter-api-key>

# Optional settings
OPENROUTER_MODEL=openai/gpt-4o-mini
# Comma-separated list shown by the /model Telegram command.
# OPENROUTER_MODELS=openai/gpt-4o-mini,anthropic/claude-sonnet-4.5,google/gemini-2.5-flash
POLL_INTERVAL_SECONDS=1800
MIN_SCORE=6
BEARISH_THRESHOLD=3
DAILY_DIGEST_HOUR=8
FEED_LOOKBACK_HOURS=2
REQUEST_TIMEOUT_SECONDS=10
AGENT_DATA_DIR=data
AGENT_LOG_DIR=logs

# Optional custom agent prompt. Use one of these, not both.
# ANALYSIS_PROMPT=Prioritize earnings, guidance, and AI infrastructure news.
# ANALYSIS_PROMPT_FILE=prompts/analysis_prompt.txt
